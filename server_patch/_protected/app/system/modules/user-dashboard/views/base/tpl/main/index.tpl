    #cboxTitle{bottom:-28px!important;left:0!important;width:100%!important;color:#f4edf8!important;font-size:13px!important;font-weight:bold!important;text-align:center!important}
    #cboxClose{top:-14px!important;right:-14px!important;bottom:auto!important;width:32px!important;height:32px!important;border:2px solid #8f4dff!important;border-radius:50%!important;background:#ff2f8d!important;color:#fff!important;text-indent:0!important;font-size:0!important;line-height:28px!important;text-align:center!important;box-shadow:0 8px 22px rgba(0,0,0,.45)!important}
    #cboxClose:before{content:"×"!important;display:block!important;font-size:22px!important;font-weight:bold!important;line-height:26px!important}
    #cboxClose:hover{background:#ff4fa0!important}
    @media (min-width:768px){.navbar-toggle{display:none!important}}
    @media (max-width:991px){.navbar-nav > li > a{padding-left:6px!important;padding-right:6px!important;font-size:12px}.sc-public-photo-row{grid-template-columns:repeat(3,minmax(0,1fr))!important}.sc-dashboard-grid{grid-template-columns:1fr!important}}
    @media (max-width:767px){main#content{padding:26px 10px 0!important}.navbar-toggle{display:block!important}.sc-dashboard-card{padding:14px!important}.sc-public-photo-row{grid-template-columns:repeat(2,minmax(0,1fr))!important}.sc-profile-actions a,.sc-dashboard-button{width:100%!important}}
</style>
