<script>
    $(document).ready(function() {
        $('ul.zoomer_pic').slick({
            dots: true,
            infinite: false,
            slidesToShow: 6,
            slidesToScroll: 6,
            adaptiveHeight: true
        })
        if ($.fn.colorbox) {
            $('.sc-public-photo-link[data-popup=image]').colorbox({
                maxWidth: '85%',
                maxHeight: '85%',
                scrolling: false,
                transition: 'fade',
                photo: true
            });
        }
    });
</script>
