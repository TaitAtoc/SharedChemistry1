                <li>
                    <a href="{{ $design->url('user','setting','edit') }}" title="{lang 'Private Photos and Videos'}">
                        <i class="fa fa-lock"></i> {lang 'Private Photos & Videos'}
                    </a>
                </li>
                <li>
                    <a href="{{ $design->url('mail','main','inbox') }}" title="{lang 'Messages'}">
